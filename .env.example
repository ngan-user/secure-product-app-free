# ============================================================
# .env.example — Template biến môi trường
# ✅ SECURITY: File này được commit lên GitHub
# ✅ SECURITY: File .env THỰC SỰ KHÔNG ĐƯỢC COMMIT (xem .gitignore)
# ============================================================

# ─── App ────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
ALLOWED_ORIGINS=https://yourdomain.com

# ─── Database ────────────────────────────────────────────────
# ✅ Thay bằng giá trị thực khi deploy
DB_HOST=mysql
DB_PORT=3306
DB_NAME=productdb
DB_USER=appuser
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ─── MySQL Root (chỉ dùng khi init container) ───────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD_HERE

# ─── JWT ─────────────────────────────────────────────────────
# ✅ Tạo bằng: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64
JWT_EXPIRES_IN=1h

# ─── Monitoring ──────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
