[mysqld]
# ============================================================
# MySQL Hardening Configuration
# ✅ DB SECURITY: Cấu hình bảo mật MySQL
# ============================================================

# ─── Bảo mật cơ bản ────────────────────────────────────────
# Tắt local file loading (ngăn LOAD DATA LOCAL INFILE attack)
local_infile                = 0

# Tắt symbolic links
symbolic_links              = 0

# Giới hạn kết nối để chống DoS
max_connections             = 100
max_connect_errors          = 10

# ─── Mã hóa và SSL ─────────────────────────────────────────
# Bật SSL (cần cert files trong production)
# ssl_ca     = /etc/mysql/ssl/ca.pem
# ssl_cert   = /etc/mysql/ssl/server-cert.pem
# ssl_key    = /etc/mysql/ssl/server-key.pem
# require_secure_transport = ON

# ─── Logging ────────────────────────────────────────────────
# ✅ LOGGING: Bật general log và slow query log
general_log                 = 1
general_log_file            = /var/log/mysql/general.log
slow_query_log              = 1
slow_query_log_file         = /var/log/mysql/slow.log
long_query_time             = 2

# Log các query không dùng index
log_queries_not_using_indexes = 1

# ─── Performance ────────────────────────────────────────────
innodb_buffer_pool_size     = 256M
innodb_log_file_size        = 64M
query_cache_type            = 0

# ─── Character set ──────────────────────────────────────────
character_set_server        = utf8mb4
collation_server            = utf8mb4_unicode_ci

# ─── Giới hạn packet ────────────────────────────────────────
max_allowed_packet          = 16M

[client]
default_character_set       = utf8mb4
